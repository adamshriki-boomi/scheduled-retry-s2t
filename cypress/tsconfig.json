{
  "compilerOptions": {
    "target": "ES2021",
    "baseUrl": "../node_modules",
    "lib": [
      "esnext",
      "dom",
    ],
    "strict": false,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "noFallthroughCasesInSwitch": true,
    "types": [
      "cypress",
      "cypress-real-events",
      "@testing-library/cypress",
      "@types/node",
      "@badeball/cypress-cucumber-preprocessor"
    ],
    "paths": {}
  },
  "include": [
    "**/*.ts",
  ]
}